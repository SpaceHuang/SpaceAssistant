{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true
  },
  "include": [
    "src/shared/**/*.ts"
  ],
  "exclude": [
    "src/shared/**/*.test.ts",
    "electron/**/*",
    "src/renderer/**/*"
  ]
}
