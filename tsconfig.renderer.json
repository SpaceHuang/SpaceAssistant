{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node", "vite/client"],
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": [
    "src/renderer/**/*.ts",
    "src/renderer/**/*.tsx",
    "src/renderer/**/*.d.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": [
    "electron/**/*",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/shared/**/*.test.ts"
  ]
}
