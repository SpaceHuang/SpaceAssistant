{
  "name": "spaceassistant",
  "version": "0.1.5",
  "private": true,
  "license": "Apache-2.0",
  "description": "Electron + React + TypeScript desktop assistant",
  "author": "SpaceAssistant",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n:generate-types": "tsx scripts/generate-i18n-types.ts",
    "i18n:check": "tsx scripts/i18n-check.ts",
    "i18n:check:strict": "tsx scripts/i18n-check.ts --strict-hardcoded",
    "predev": "npm run i18n:generate-types",
    "prebuild:renderer": "npm run i18n:generate-types",
    "dev:renderer": "vite --strictPort",
    "dev:electron": "npm run build:electron:incremental && electron dist-electron/electron/main.js",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:renderer": "vite build",
    "build:tray-icons": "node scripts/build-tray-icons.mjs",
    "build:electron": "rimraf dist-electron && tsc -p tsconfig.electron.json",
    "build:electron:incremental": "tsc -p tsconfig.electron.json",
    "build": "npm run build:tray-icons && npm run build:renderer && npm run build:electron",
    "rebuild:native": "node scripts/install-sqlite-bindings.mjs",
    "postinstall": "node scripts/install-sqlite-bindings.mjs",
    "typecheck:renderer": "tsc -p tsconfig.renderer.json --noEmit",
    "typecheck:shared": "node scripts/check-shared-config-types.mjs",
    "probe:sqlite": "electron scripts/probe-better-sqlite3.mjs",
    "verify:macos-app": "node scripts/verify-macos-app-signature.mjs",
    "prepack": "node scripts/install-sqlite-bindings.mjs",
    "prepack:win": "node scripts/install-sqlite-bindings.mjs",
    "prepack:mac": "node scripts/install-sqlite-bindings.mjs",
    "reinstall:electron": "rimraf node_modules/electron && npm install",
    "pack": "npm run build && electron-builder",
    "pack:win": "npm run build && electron-builder --win",
    "pack:mac": "npm run build && electron-builder --mac",
    "pack:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.79.0",
    "@browserbasehq/stagehand": "^3.0.0",
    "@reduxjs/toolkit": "^2.5.0",
    "@wechatbot/wechatbot": "^2.2.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/xterm": "^5.5.0",
    "antd": "^5.22.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.11.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "katex": "^0.17.0",
    "lucide-react": "^0.468.0",
    "node-abi": "^4.33.0",
    "playwright": "^1.52.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-markdown": "^9.0.1",
    "react-redux": "^9.2.0",
    "react-syntax-highlighter": "^15.6.1",
    "rehype-external-links": "^3.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "shiki": "^4.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "node-gyp": "^12.4.0",
    "png-to-ico": "^2.1.8",
    "rimraf": "^6.0.1",
    "sharp": "^0.33.5",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^4.1.0"
  },
  "build": {
    "publish": null,
    "appId": "com.spaceassistant.app",
    "productName": "SpaceAssistant",
    "icon": "res/icons/sa-logo-512.png",
    "npmRebuild": false,
    "asarUnpack": [
      "**/better-sqlite3/**"
    ],
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "directories": {
      "output": "release"
    },
    "afterPack": "scripts/after-pack.cjs",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "resources/tray/**",
      "package.json",
      "node_modules/better-sqlite3/**",
      "!**/node_modules/bufferutil/**"
    ],
    "extraResources": [
      {
        "from": "resources/tray",
        "to": "tray"
      },
      {
        "from": "res/icons",
        "to": "icons",
        "filter": [
          "sa-logo-256.png",
          "dark/sa-logo-dark-256.png"
        ]
      }
    ],
    "win": {
      "icon": "res/icons/sa-logo.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "1033"
    },
    "mac": {
      "icon": "res/icons/sa-logo-1024.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "res/icons/sa-logo-512.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
